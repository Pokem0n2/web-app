{
  "appId": "com.ces.viewer",
  "appName": "CES Viewer",
  "webDir": "dist",
  "server": {
    "androidScheme": "http",
    "hostname": "localhost",
    "enableOnBackPress": false
  },
  "plugins": {
    "StatusBar": {
      "overlaysWebView": true,
      "style": "dark",
      "backgroundColor": "#000000"
    },
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#000000",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    }
  },
  "android": {
    "backgroundColor": "#000000",
    "allowMixedContent": true
  }
}
